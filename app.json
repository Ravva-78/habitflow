{
  "expo": {
    "name": "HabitFlow",
    "slug": "habitflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "android": {
      "package": "com.arjun.habitflow",
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.arjun.habitflow",
      "buildNumber": "1"
    },
    "plugins": [
      "expo-sensors",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00E5CC"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6a9acb2e-b326-44d7-a790-99fcb21e20f6"
      }
    }
  }
}
